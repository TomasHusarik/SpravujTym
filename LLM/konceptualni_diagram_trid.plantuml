@startuml
top to bottom direction
!theme plain
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam ranksep 45
skinparam nodesep 30
hide circle
hide methods

title Konceptualni diagram trid - domenovy model aplikace SpravujTym

class User {
  +jmeno
  +prijmeni
  +email
  +telefon
  +datumNarozeni
  +aktivni
}

class Team {
  +nazev
  +zkratka
  +mesto
}

class Squad {
  +nazev
}

class League {
  +nazev
  +sezona
  +kategorie
}

class Membership {
  +role
  +aktivni
}

class TeamEvent {
  +nazev
  +typ
  +zacatek
  +konec
}

class EventParticipation {
  +stavUcasti
}

class Venue {
  +nazev
  +mesto
  +adresa
  +kapacita
}

class Comment {
  +obsah
  +casVytvoreni
}

class Announcement {
  +nadpis
  +obsah
  +viditelnost
  +pripnuto
}

class Payment {
  +castka
  +splatnost
  +stav
  +typ
}

User -[hidden]right- Team
Team -[hidden]right- Squad
Squad -[hidden]right- League
Venue -[hidden]down- TeamEvent
TeamEvent -[hidden]down- EventParticipation
EventParticipation -[hidden]left- Comment
Comment -[hidden]left- Announcement
Announcement -[hidden]left- Payment

Team "1" -- "1..*" Squad : obsahuje
League "1" -- "0..*" Squad : zarazuje
Team "1" -- "1" Venue : domovske zazemi

User "1" -- "0..*" Squad : clenstvi
(User, Squad) .. Membership

Squad "0..*" -- "0..*" TeamEvent : ucastni se
Venue "0..1" -- "0..*" TeamEvent : kona se na
User "1" -- "0..*" TeamEvent : vytvari

User "1" -- "0..*" TeamEvent : reaguje na ucast
(User, TeamEvent) .. EventParticipation

User "1" -- "0..*" Comment : pise
TeamEvent "1" -- "0..*" Comment : obsahuje

User "1" -- "0..*" Announcement : publikuje
User "1" -- "0..*" Payment : ma prirazenu platbu

@enduml
