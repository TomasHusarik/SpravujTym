@startuml
top to bottom direction
!theme plain
skinparam shadowing false
skinparam linetype ortho
skinparam ranksep 35
skinparam nodesep 20

title Deployment diagram - Nasazeni aplikace SpravujTym

node "Klientske zarizeni" as ClientDevice {
  node "Webovy prohlizec" as Browser {
    artifact "React klient\n(SPA)" as FrontendApp
  }
}

node "Aplikacni server" as Hosting {
  node "Node.js runtime" as NodeRuntime {
    artifact "Express aplikace" as ApiServer
    artifact "REST API" as RestApi
    artifact "Middleware vrstva\n(auth, permissions, guards)" as Middleware
    artifact "Vrstva controlleru" as Controllers
    artifact "Mongoose modely" as Models
  }

  folder "Staticke soubory" as StaticFiles {
    artifact "Build frontend klienta" as FrontendBundle
  }

  database "MongoDB" as MongoDb
}

cloud "Emailova sluzba" as Resend

collections "Cookies v prohlizeci" as Cookies

FrontendApp --> RestApi : HTTPS / JSON
Browser --> Cookies : ulozeni JWT cookie
RestApi --> Middleware
Middleware --> Controllers
Controllers --> Models
Models --> MongoDb : Mongoose dotazy

ApiServer --> FrontendBundle : servirovani buildu v produkci
Controllers --> Resend : registracni,\nnomincni a informacni emaily

note right of Middleware
  Autentizace vyuziva JWT
  ulozene v HTTP-only cookie.
end note

note right of MongoDb
  Databaze uklada uzivatele,
  tymy, soupisky, udalosti,
  ucasti, komentare a platby.
end note

@enduml
