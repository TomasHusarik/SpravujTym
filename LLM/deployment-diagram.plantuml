@startuml
top to bottom direction
!theme plain
skinparam shadowing false
skinparam linetype ortho
skinparam ranksep 35
skinparam nodesep 20

title Deployment diagram - Nasazeni aplikace SpravujTym

node "Uzivatelovo zarizeni" as ClientDevice {
  node "Webovy prohlizec" as Browser {
    artifact "React SPA\n(Vite build)" as FrontendApp
  }
}

node "Hosting aplikace" as Hosting {
  node "Node.js runtime" as NodeRuntime {
    artifact "Express API server" as ApiServer
    artifact "REST endpointy" as RestApi
    artifact "Middleware vrstva\n(auth, permissions, guards)" as Middleware
    artifact "Business logika controlleru" as Controllers
    artifact "Mongoose modely" as Models
  }

  folder "Staticke soubory klienta" as StaticFiles {
    artifact "HTML / CSS / JS bundle" as FrontendBundle
  }

  database "MongoDB" as MongoDb
}

cloud "Emailova sluzba Resend" as Resend

collections "Cookies v prohlizeci" as Cookies

FrontendApp --> RestApi : HTTPS / JSON
Browser --> Cookies : ulozeni JWT cookie
RestApi --> Middleware
Middleware --> Controllers
Controllers --> Models
Models --> MongoDb : Mongoose dotazy

ApiServer --> FrontendBundle : servirovani buildu v produkci
Controllers --> Resend : registracni,\nnominační a informacni emaily

note right of Middleware
  Autentizace probiha pomoci JWT
  ulozeneho v HTTP-only cookie.
end note

note right of MongoDb
  Databaze uchovava uzivatele,
  tymy, soupisky, udalosti,
  ucasti, komentare a platby.
end note

@enduml
